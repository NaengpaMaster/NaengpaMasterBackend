# application-secret.env.example
# 이 파일을 복사해 실제 값을 채운 뒤 application-secret.env 로 저장하세요.
#   cp application-secret.env.example application-secret.env
# ⚠️ application-secret.env 는 .gitignore 대상입니다. 절대 커밋하지 마세요.

# --- Database ---
DB_URL=
DB_DRIVER_CLASS_NAME=
DB_USERNAME=
DB_PASSWORD=

# --- JPA ---
JPA_DDL_AUTO=
JPA_OPEN_IN_VIEW=

# --- JWT ---
JWT_SECRET=
JWT_EXPIRATION=
JWT_REFRESH_EXPIRATION=

# --- Mail (이메일 인증) ---
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
